    "@tailwindcss/postcss": "^4.1.13",
    "autoprefixer": "^10.4.20",
    "axios": "^1.14.0",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "googleapis": "^171.4.0",
