{
  "name": "merlin",
  "version": "2.0.0",
  "description": "Merlin — Angel OS media server: local media serving + ingest, ffmpeg rollups, a Leo channel, and a federation client",
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "dev:https": "next dev -H 0.0.0.0 -p 3000 --experimental-https",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "next lint",
    "icons": "node scripts/generate-icons.mjs",
    "payload": "payload",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@angel-os/brain": "file:../angel-brain",
