    "next": "^15.5.4",
    "node-schedule": "^2.1.1",
    "payload": "3.77.0",
    "postcss": "^8.4.49",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sharp": "^0.34.4",
